# Get an API key from https://resend.com/api-keys
RESEND_API_KEY=

# Verified sending address in your Resend account.
# Leave unset to use Resend's shared test domain (onboarding@resend.dev),
# which only delivers to the email the Resend account was signed up with.
CONTACT_FROM_EMAIL=

# Inbox that receives contact form submissions.
CONTACT_TO_EMAIL=connect@thesocialnexus.co.uk
