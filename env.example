# SMTP credentials used by Nodemailer (lib/email.ts) to send form-submission
# emails. Any SMTP provider works (Gmail app password, SendGrid, Mailgun,
# Amazon SES, your own mail server, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sending address shown in the "From" header. Falls back to SMTP_USER if
# unset — most providers require the From address to match (or be verified
# against) the authenticated SMTP account anyway.
CONTACT_FROM_EMAIL=

# Inbox that receives every form submission (contact, hero quick-enquiry,
# web brief, logo brief).
CONTACT_TO_EMAIL=connect@thesocialnexus.co.uk
